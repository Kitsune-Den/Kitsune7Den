<UserControl x:Class="Kitsune7Den.Views.PlayersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Kitsune7Den.Models">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource SectionHeader}" Text="Online Players" Margin="0" />
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"
                           Margin="12,0,0,0">
                    <Run Text="{Binding Players.Count, Mode=OneWay}" />
                    <Run Text="online" />
                </TextBlock>
            </StackPanel>
            <Button Content="Refresh" Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right"
                    Command="{Binding RefreshCommand}" HorizontalAlignment="Right" />
        </DockPanel>

        <!-- Player Cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Players}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:PlayerInfo}">
                        <Border Background="{DynamicResource BgMediumBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,12" Padding="0">
                            <DockPanel>
                                <!-- Admin accent border -->
                                <Border DockPanel.Dock="Left" Width="4" CornerRadius="8,0,0,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BgLightBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <Grid Margin="16,14,16,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Name + Admin Badge + Actions -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Player icon -->
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <!-- Admin badge -->
                                            <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding PermissionLabel}" FontSize="10" FontWeight="Bold"
                                                           Foreground="#FF1a1a2e" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Kick" Style="{StaticResource SecondaryButton}" Padding="10,4"
                                                    FontSize="11"
                                                    Command="{Binding DataContext.KickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Tag="{Binding}" />
                                            <Button Style="{StaticResource ActionButton}" Padding="10,4"
                                                    FontSize="11" Margin="6,0,0,0"
                                                    Command="{Binding DataContext.BanCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Ban" />
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Row 2: Stats Grid -->
                                    <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,10">
                                        <!-- Level -->
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="LEVEL" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Level}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="15" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <!-- Health -->
                                        <StackPanel>
                                            <TextBlock Text="HEALTH" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Health}" FontSize="15" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Health}" Value="0">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- Score -->
                                        <StackPanel>
                                            <TextBlock Text="SCORE" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Score}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="15" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <!-- Zombie Kills -->
                                        <StackPanel>
                                            <TextBlock Text="ZOMBIES" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding ZombieKills}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="15" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <!-- Deaths -->
                                        <StackPanel>
                                            <TextBlock Text="DEATHS" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Deaths}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="15" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <!-- Ping -->
                                        <StackPanel>
                                            <TextBlock Text="PING" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Ping}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="15" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <!-- Row 3: Position + Admin controls -->
                                    <DockPanel Grid.Row="2">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                            <TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                       Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding PositionText}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="16,0,0,0">
                                                <Run Text="IP: " />
                                                <Run Text="{Binding Ip, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Admin toggle buttons -->
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <!-- Give Admin (shown when NOT admin) -->
                                            <Button Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="10"
                                                    Command="{Binding DataContext.GiveAdminCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                                <Button.Visibility>
                                                    <Binding Path="IsAdmin" Converter="{StaticResource InverseBoolVis}" />
                                                </Button.Visibility>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               VerticalAlignment="Center" Margin="0,0,5,0" />
                                                    <TextBlock Text="Give Admin" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <!-- Remove Admin (shown when IS admin) -->
                                            <Button Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="10"
                                                    Command="{Binding DataContext.RemoveAdminCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               VerticalAlignment="Center" Margin="0,0,5,0" />
                                                    <TextBlock Text="Remove Admin" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
