<Window x:Class="Kitsune7Den.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kitsune7Den"
        xmlns:views="clr-namespace:Kitsune7Den.Views"
        xmlns:vm="clr-namespace:Kitsune7Den.ViewModels"
        Title="Kitsune7Den" Width="1100" Height="700" MinWidth="800" MinHeight="500"
        Background="{DynamicResource BgDarkBrush}" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/icon.ico">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConsoleViewModel}">
            <views:ConsoleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlayersViewModel}">
            <views:PlayersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
            <views:ConfigView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModsViewModel}">
            <views:ModsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupsViewModel}">
            <views:BackupsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo: full sidebar width, touches the top. KITSUNE7DEN branding baked in. -->
                <Image DockPanel.Dock="Top" Source="pack://application:,,,/Resources/logo.png"
                       Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,0,12" />

                <!-- Version info at very bottom -->
                <TextBlock DockPanel.Dock="Bottom" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="10" Opacity="0.5" Margin="20,0,0,10"
                           Text="{x:Static local:App.AppVersion}" />

                <!-- Settings pinned to bottom (must dock before fill child) -->
                <Button DockPanel.Dock="Bottom" Style="{StaticResource NavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Settings" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Settings" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Nav Items (fills remaining space) -->
                <StackPanel>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Console">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Console" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Players">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Players" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Config">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Configuration" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Mods">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Mods" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Backups">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Backups" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Logs">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Logs" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Grid.Row="0" Content="{Binding CurrentView}" />

        <!-- Status Bar -->
        <Border Grid.Column="1" Grid.Row="1" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left">
                    <Run Text="Server: " Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Run Text="{Binding ServerStateText}" Foreground="{DynamicResource TextPrimaryBrush}" />
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Run Text="Telnet: " Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Run Text="{Binding TelnetStateText}" Foreground="{DynamicResource TextPrimaryBrush}" />
                </TextBlock>
                <TextBlock HorizontalAlignment="Center">
                    <Run Text="Players: " Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Run Text="{Binding PlayerCount}" Foreground="{DynamicResource TextPrimaryBrush}" />
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
