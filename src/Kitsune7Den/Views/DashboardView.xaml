<UserControl x:Class="Kitsune7Den.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Kitsune7Den.Converters">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusColor" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="700">

            <!-- Welcome / First-run card — only shown when no server is configured -->
            <Border Background="{DynamicResource BgMediumBrush}" CornerRadius="8"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    Margin="0,0,0,16" Padding="0"
                    Visibility="{Binding IsFirstRun, Converter={StaticResource BoolVis}}">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="4" CornerRadius="8,0,0,8"
                            Background="{DynamicResource AccentBrush}" />
                    <StackPanel Margin="20,16,20,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="Welcome to Kitsune7Den" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Margin="0,0,0,10">
                            <Run Text="Let's get your server wired up. Pick one:" />
                        </TextBlock>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4">
                                <Run Text="• " Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" />
                                <Run Text="Already installed?" FontWeight="SemiBold" />
                                <Run Text=" Click " Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Run Text="Browse" FontWeight="SemiBold" />
                                <Run Text=" below and point to your " Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Run Text="7DaysToDieServer.exe" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12">
                                <Run Text="• " Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" />
                                <Run Text="Starting fresh?" FontWeight="SemiBold" />
                                <Run Text=" Head to " Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Run Text="Settings → SteamCMD" FontWeight="SemiBold" />
                                <Run Text=" and Kitsune7Den will install the server for you" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Server Path Config -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Server Location" />
                    <TextBlock Text="Point this to your 7DaysToDieServer.exe (or install one via Settings)"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseExeCommand}" Margin="8,0,0,0" />
                        <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding ServerExePath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 ToolTip="Path to 7DaysToDieServer.exe — use Browse or set up SteamCMD in Settings to auto-install" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Status -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Server Status" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- State -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Ellipse Width="12" Height="12" HorizontalAlignment="Center" Margin="0,0,0,6"
                                     Fill="{Binding ServerState, Converter={StaticResource StatusColor}}" />
                            <TextBlock Text="{Binding ServerState}" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="State" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Uptime -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding UptimeText}" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,18,0,0" />
                            <TextBlock Text="Uptime" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Players -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding PlayerCount}" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,18,0,0" />
                            <TextBlock Text="Players" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Controls -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Controls" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Start" Style="{StaticResource ActionButton}"
                                Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"
                                Width="120" Margin="0,0,8,0" />
                        <Button Content="Stop" Style="{StaticResource SecondaryButton}"
                                Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                                Width="120" Margin="0,0,8,0" />
                        <Button Content="Connect Telnet" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ConnectTelnetCommand}"
                                Width="130" Margin="0,0,8,0"
                                ToolTip="Manually connect telnet — use when the server is already running" />
                        <Button Content="Restart" Style="{StaticResource SecondaryButton}"
                                Command="{Binding RestartCommand}" IsEnabled="{Binding CanStop}"
                                Width="120" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Connection Info -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Connection Info" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LAN -->
                        <Border Grid.Column="0" Background="#FF0d0d1a" CornerRadius="6" Padding="12,10" Margin="0,0,6,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CopyLanCommand}" Padding="8,4" FontSize="11"
                                        ToolTip="Copy LAN address to clipboard" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="LAN" Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,2" />
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontFamily="Consolas">
                                        <Run Text="{Binding LanIp, Mode=OneWay}" />
                                        <Run Text=":" />
                                        <Run Text="{Binding ServerPort, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Public -->
                        <Border Grid.Column="1" Background="#FF0d0d1a" CornerRadius="6" Padding="12,10" Margin="6,0,0,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CopyPublicCommand}" Padding="8,4" FontSize="11"
                                        ToolTip="Copy public address to clipboard" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PUBLIC" Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,2" />
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontFamily="Consolas">
                                        <Run Text="{Binding PublicIp, Mode=OneWay}" />
                                        <Run Text=":" />
                                        <Run Text="{Binding ServerPort, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
