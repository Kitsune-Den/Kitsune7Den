<UserControl x:Class="Kitsune7Den.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Kitsune7Den.ViewModels"
             xmlns:models="clr-namespace:Kitsune7Den.Models"
             Loaded="OnLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,12">
            <DockPanel>
                <!-- Title -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Server Configuration" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="  (serverconfig.xml)" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,1" />
                </StackPanel>

                <!-- Right-side buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- View Toggle -->
                    <Border CornerRadius="6" Background="#FF0d0d1a" Padding="2" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Form View" Command="{Binding SwitchToFormCommand}"
                                    Padding="10,5" FontSize="12" Cursor="Hand" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFormView}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgLightBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Raw XML" Command="{Binding SwitchToRawCommand}"
                                    Padding="10,5" FontSize="12" Cursor="Hand" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFormView}" Value="False">
                                                <Setter Property="Background" Value="{DynamicResource BgLightBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Button Content="Reset" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResetCommand}" Margin="0,0,8,0" />
                    <Button Content="Save Changes" Style="{StaticResource ActionButton}"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding HasChanges}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Form View -->
        <!-- Empty state — no server configured -->
        <Grid Grid.Row="1" Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460">
                <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           Opacity="0.5" Margin="0,0,0,16" />
                <TextBlock Text="No server configured" Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                    <Run Text="Go to the Dashboard and browse to your " />
                    <Run Text="7DaysToDieServer.exe" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Run Text=" — or install a new server from the Settings page via SteamCMD." />
                </TextBlock>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsFormView}" Value="True" />
                                <Condition Binding="{Binding IsEmpty}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ConfigGroup}">
                        <!-- Category Card -->
                        <Border Background="{DynamicResource BgMediumBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,16" Padding="0">
                            <DockPanel>
                                <!-- Accent left border -->
                                <Border DockPanel.Dock="Left" Width="4" CornerRadius="8,0,0,8"
                                        Background="{DynamicResource AccentBrush}" />

                                <StackPanel Margin="20,16,20,20">
                                    <!-- Category Header -->
                                    <TextBlock Text="{Binding NameUpper}" Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="Bold" Margin="0,0,0,16" />

                                    <!-- Day/Night Calculator (Gameplay only) — ported from KitsuneDen -->
                                    <Border Background="#FF0d0d1a" CornerRadius="6" Padding="16,14" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Name}" Value="Gameplay">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <TextBlock Text="DAY / NIGHT CYCLE" Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,10" />

                                            <!-- Two sliders side-by-side -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Day -->
                                                <StackPanel Grid.Column="0">
                                                    <DockPanel Margin="0,0,0,4">
                                                        <TextBlock Text="DAY" DockPanel.Dock="Left"
                                                                   Foreground="{DynamicResource WarningBrush}"
                                                                   FontSize="10" FontWeight="Bold" />
                                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11">
                                                            <Run Text="{Binding DayMinutes, Mode=OneWay}" FontWeight="SemiBold" />
                                                            <Run Text=" min" Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        </TextBlock>
                                                    </DockPanel>
                                                    <Slider Minimum="1" Maximum="239"
                                                            Value="{Binding DayMinutes, Mode=TwoWay, Delay=100}"
                                                            IsSnapToTickEnabled="True" TickFrequency="1"
                                                            Foreground="{DynamicResource WarningBrush}" />
                                                </StackPanel>

                                                <!-- Night -->
                                                <StackPanel Grid.Column="2">
                                                    <DockPanel Margin="0,0,0,4">
                                                        <TextBlock Text="NIGHT" DockPanel.Dock="Left"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="10" FontWeight="Bold" />
                                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11">
                                                            <Run Text="{Binding NightMinutes, Mode=OneWay}" FontWeight="SemiBold" />
                                                            <Run Text=" min" Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        </TextBlock>
                                                    </DockPanel>
                                                    <Slider Minimum="1" Maximum="239"
                                                            Value="{Binding NightMinutes, Mode=TwoWay, Delay=100}"
                                                            IsSnapToTickEnabled="True" TickFrequency="1"
                                                            Foreground="{DynamicResource AccentBrush}" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Total cycle + visual day% bar -->
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock DockPanel.Dock="Right" Margin="10,0,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" VerticalAlignment="Center">
                                                    <Run Text="{Binding DayNightTotal, Mode=OneWay}" FontWeight="SemiBold"
                                                         Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <Run Text=" min total" />
                                                </TextBlock>
                                                <Border Height="6" CornerRadius="3" Background="{DynamicResource BorderBrush}"
                                                        VerticalAlignment="Center">
                                                    <Grid HorizontalAlignment="Left">
                                                        <Grid.Width>
                                                            <MultiBinding StringFormat="{}{0}">
                                                                <Binding Path="DayPercent" />
                                                            </MultiBinding>
                                                        </Grid.Width>
                                                        <Border Height="6" CornerRadius="3"
                                                                Background="{DynamicResource WarningBrush}"
                                                                HorizontalAlignment="Stretch" />
                                                    </Grid>
                                                </Border>
                                            </DockPanel>

                                            <!-- Total cycle editable input -->
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBlock Text="Total cycle:" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBox Style="{StaticResource DarkTextBox}" Width="60"
                                                         Text="{Binding DayNightTotal, Mode=OneWay}"
                                                         KeyDown="TotalCycleBox_KeyDown" />
                                                <TextBlock Text="min  (10 – 240)" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            </StackPanel>

                                            <!-- Raw preview -->
                                            <TextBlock Text="{Binding DayNightRawPreview}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="10" Opacity="0.7" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Properties in wrap panel (2-col layout) -->
                                    <ItemsControl ItemsSource="{Binding Properties}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ServerConfigProperty}">
                                                <StackPanel Width="330" Margin="0,0,24,16">
                                                    <!-- Field Label -->
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11" Margin="0,0,0,4" />

                                                    <!-- Field Input (chosen by type) -->
                                                    <ContentControl>
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <!-- Default: TextBox -->
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <TextBox Style="{StaticResource DarkTextBox}"
                                                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="Select">
                                                                        <Setter Property="Content">
                                                                            <Setter.Value>
                                                                                <ComboBox ItemsSource="{Binding SelectOptions}"
                                                                                          SelectedItem="{Binding SelectedOption}"
                                                                                          DisplayMemberPath="Label" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="Boolean">
                                                                        <Setter Property="Content">
                                                                            <Setter.Value>
                                                                                <ComboBox SelectedItem="{Binding Value}">
                                                                                    <ComboBoxItem Content="true" />
                                                                                    <ComboBoxItem Content="false" />
                                                                                </ComboBox>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="Password">
                                                                        <Setter Property="Content">
                                                                            <Setter.Value>
                                                                                <TextBox Style="{StaticResource DarkTextBox}"
                                                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="EditableSelect">
                                                                        <Setter Property="Content">
                                                                            <Setter.Value>
                                                                                <ComboBox ItemsSource="{Binding Options}"
                                                                                          Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                                          IsEditable="True" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>

                                                    <!-- Description -->
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"
                                                               Opacity="0.7" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Raw XML View -->
        <Grid Grid.Row="1" Margin="24,16,24,24"
              Visibility="{Binding IsFormView, Converter={StaticResource InverseBoolVis}}">
            <TextBox Style="{StaticResource DarkTextBox}"
                     Text="{Binding RawXml, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas" FontSize="12"
                     AcceptsReturn="True" AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" />
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                   VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Margin="24,0,0,8" />
    </Grid>
</UserControl>
