<UserControl x:Class="Kitsune7Den.Views.BackupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Kitsune7Den.Models"
             xmlns:local="clr-namespace:Kitsune7Den.ViewModels"
             Loaded="OnLoaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource SectionHeader}" Text="Backups" Margin="0,0,0,4" />
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                    <Run Text="Save: " />
                    <Run Text="{Binding SaveDirectory, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <Button Content="Open Folder" Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenBackupFolderCommand}" Margin="0,0,8,0" />
                <Button Content="Refresh" Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                <Button Style="{StaticResource ActionButton}"
                        Command="{Binding CreateBackupCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Create Backup" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Schedule Config -->
        <Border Grid.Row="1" Background="{DynamicResource BgMediumBrush}" CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="0" Margin="0,0,0,16">
            <DockPanel>
                <Border DockPanel.Dock="Left" Width="4" CornerRadius="8,0,0,8"
                        Background="{DynamicResource SuccessBrush}" />
                <Grid Margin="16,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Enable toggle -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="SCHEDULED" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3" />
                        <CheckBox IsChecked="{Binding ScheduledEnabled}" Content="Enabled"
                                  Foreground="{DynamicResource TextPrimaryBrush}" VerticalContentAlignment="Center" />
                    </StackPanel>

                    <!-- Interval -->
                    <StackPanel Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="INTERVAL" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3" />
                        <ComboBox ItemsSource="{x:Static local:BackupsViewModel.IntervalOptions}"
                                  SelectedValue="{Binding SelectedInterval}"
                                  SelectedValuePath="Value" DisplayMemberPath="Label"
                                  Width="170" />
                    </StackPanel>

                    <!-- Max backups -->
                    <StackPanel Grid.Column="2" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="MAX BACKUPS" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3" />
                        <TextBox Style="{StaticResource DarkTextBox}" Width="60"
                                 Text="{Binding MaxBackups, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Save + Status -->
                    <StackPanel Grid.Column="3" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="&#x200B;" FontSize="9" Margin="0,0,0,3" /> <!-- spacer -->
                        <Button Content="Save Schedule" Style="{StaticResource ActionButton}"
                                Command="{Binding SaveScheduleCommand}" Padding="12,5" FontSize="12" />
                    </StackPanel>

                    <!-- Next backup indicator -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="NEXT BACKUP" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3" HorizontalAlignment="Right" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScheduleRunning}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding NextBackupText}" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Empty state -->
        <Grid Grid.Row="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Backups.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460">
                <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           Opacity="0.5" Margin="0,0,0,16" />
                <TextBlock Text="No backups yet" Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                    <Run Text="Hit " />
                    <Run Text="Create Backup" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Run Text=" to zip up your current save, or enable the schedule above to auto-backup at a regular interval." />
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Backup List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Backups.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <ItemsControl ItemsSource="{Binding Backups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:BackupInfo}">
                        <Border Background="{DynamicResource BgMediumBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,8" Padding="0" Cursor="Hand"
                                MouseLeftButtonUp="BackupCard_Click" Tag="{Binding}">
                            <DockPanel>
                                <!-- Type accent -->
                                <Border DockPanel.Dock="Left" Width="4" CornerRadius="8,0,0,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BgLightBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BackupType}" Value="manual">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding BackupType}" Value="pre-restore">
                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding BackupType}" Value="scheduled">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <Grid Margin="14,10,14,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="13" FontWeight="SemiBold" />
                                            <!-- Type badge -->
                                            <Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                    VerticalAlignment="Center" Background="{DynamicResource BgLightBrush}">
                                                <TextBlock Text="{Binding BackupType}" FontSize="9"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding TimeAgo}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock Text=" | " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                                            <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock Text=" | " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Restore -->
                                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                            Padding="10,5" FontSize="11" Margin="8,0,0,0"
                                            Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            VerticalAlignment="Center"
                                            Tag="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <TextBlock Text="Restore" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <!-- Delete -->
                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                            Padding="10,5" FontSize="11" Margin="6,0,0,0"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            VerticalAlignment="Center"
                                            Tag="{Binding}">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,8,0,0" />
    </Grid>
</UserControl>
