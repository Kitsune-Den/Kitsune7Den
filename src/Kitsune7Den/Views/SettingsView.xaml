<UserControl x:Class="Kitsune7Den.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Kitsune7Den"
             xmlns:converters="clr-namespace:Kitsune7Den.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="750">

            <!-- App Updates -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Updates" Margin="0"
                                   DockPanel.Dock="Left" />
                        <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Text="{Binding CurrentAppVersion}" />
                    </DockPanel>
                    <TextBlock Text="Check GitHub for the latest release of Kitsune7Den. Updates are downloaded and installed in-place — no installer needed."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding CheckAppUpdateCommand}"
                                IsEnabled="{Binding IsCheckingUpdate, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Check for Updates" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Content="Install Update" Style="{StaticResource ActionButton}"
                                Command="{Binding InstallAppUpdateCommand}" Margin="8,0,0,0"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}"
                                IsEnabled="{Binding IsDownloadingUpdate, Converter={StaticResource InverseBool}}" />
                        <Button Content="View on GitHub" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ViewReleaseCommand}" Margin="8,0,0,0"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}" />
                    </StackPanel>

                    <!-- Available version badge -->
                    <Border CornerRadius="4" Padding="8,5" Margin="0,10,0,0"
                            Background="#FF0d0d1a" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}">
                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11">
                            <Run Text="Update available: " Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Run Text="{Binding LatestAppVersion, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{DynamicResource AccentBrush}" />
                        </TextBlock>
                    </Border>

                    <!-- Progress bar while downloading -->
                    <ProgressBar Height="6" Minimum="0" Maximum="1" Value="{Binding UpdateProgress, Mode=OneWay}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="{DynamicResource BorderBrush}" BorderThickness="0"
                                 Margin="0,10,0,0"
                                 Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolVis}}" />

                    <TextBlock Text="{Binding UpdateStatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,8,0,0"
                               Visibility="{Binding UpdateStatusMessage, Converter={StaticResource StringVis}}" />
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Appearance" />
                    <TextBlock Text="Theme" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme}" Width="200" />
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTheme}" Value="Kitsune">
                                            <Setter Property="Text" Value="Deep navy + red accent (default)" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTheme}" Value="Midnight">
                                            <Setter Property="Text" Value="Dark charcoal + cool blue accent" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTheme}" Value="Forest">
                                            <Setter Property="Text" Value="Dark green tones + amber accent" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTheme}" Value="Accessible">
                                            <Setter Property="Text" Value="High contrast, colorblind-friendly (blue/orange, no red/green)" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"
                               Opacity="0.5" Margin="0,12,0,0">
                        <Run Text="{x:Static local:App.AppVersion}" /><Run Text=" | " />
                        <Hyperlink NavigateUri="https://github.com/AdaInTheLab/Kitsune7Den"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            github.com/AdaInTheLab/Kitsune7Den
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Support the Project -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Support the Project" />
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,12">
                        Kitsune7Den is free and open source. If it saves you time or makes your server life easier, you can buy me a coffee. No pressure, only gratitude.
                    </TextBlock>
                    <Button HorizontalAlignment="Left" Cursor="Hand" BorderThickness="0"
                            Padding="16,10" Background="#FF330447"
                            Click="KofiButton_Click"
                            ToolTip="Opens ko-fi.com in your default browser">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#FF4a0866" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☕" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Support me on Ko-fi" Foreground="White"
                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- SteamCMD Section -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="SteamCMD" />
                    <TextBlock Text="SteamCMD lets you install and update the 7D2D dedicated server directly."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12" />

                    <!-- SteamCMD Path -->
                    <TextBlock Text="SteamCMD Path" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseSteamCmdCommand}" Margin="8,0,0,0" />
                        <Button DockPanel.Dock="Right" Content="Download" Style="{StaticResource ActionButton}"
                                Command="{Binding DownloadSteamCmdCommand}" Margin="8,0,0,0"
                                IsEnabled="{Binding IsUpdating, Converter={StaticResource InverseBool}}"
                                ToolTip="Downloads SteamCMD automatically" />
                        <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding SteamCmdPath, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Path to steamcmd.exe" />
                    </DockPanel>

                    <!-- Status indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SteamCmdAvailable}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="SteamCMD not found" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SteamCmdAvailable}" Value="True">
                                            <Setter Property="Text" Value="SteamCMD ready" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Server Install Section -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Server Installation" />

                    <!-- Install Directory -->
                    <TextBlock Text="Install Directory" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseInstallDirCommand}" Margin="8,0,0,0" />
                        <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding ServerInstallDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Where the 7D2D server files will be installed" />
                    </DockPanel>

                    <!-- Branch / Version -->
                    <TextBlock Text="Server Branch" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}"
                              IsEditable="True" Margin="0,0,0,12" Padding="8,6" FontSize="13"
                              ToolTip="Select a known branch or type a custom one (e.g. alpha21.2)" />

                    <!-- Options -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox Content="Auto-update on server start" IsChecked="{Binding AutoUpdateOnStart}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,24,0" VerticalContentAlignment="Center" />
                        <CheckBox Content="Validate files" IsChecked="{Binding ValidateOnUpdate}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" VerticalContentAlignment="Center"
                                  ToolTip="Runs file validation during update (slower but fixes corrupted files)" />
                    </StackPanel>

                    <!-- Install/Update button -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Install / Update Server" Style="{StaticResource ActionButton}"
                                Command="{Binding InstallOrUpdateCommand}"
                                IsEnabled="{Binding IsUpdating, Converter={StaticResource InverseBool}}"
                                Margin="0,0,8,0" />
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelUpdateCommand}"
                                Visibility="{Binding IsUpdating, Converter={StaticResource BoolVis}}" />
                    </StackPanel>

                    <!-- Update Log -->
                    <ListBox ItemsSource="{Binding UpdateLog}" MaxHeight="200"
                             Background="#FF0d0d1a" Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             FontFamily="Consolas" FontSize="11"
                             Visibility="{Binding IsUpdating, Converter={StaticResource BoolVis}}"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,1" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Telnet Section -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Telnet Connection" />
                    <TextBlock Text="These should match the values in your serverconfig.xml. Kitsune7Den uses telnet to send commands and read player data."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Telnet Port" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding TelnetPort, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Telnet Password" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4" />
                            <PasswordBox x:Name="TelnetPasswordBox" Style="{StaticResource DarkPasswordBox}"
                                         Loaded="TelnetPasswordBox_Loaded"
                                         PasswordChanged="TelnetPasswordBox_Changed" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save + Status -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                <Button Content="Save All Settings" Style="{StaticResource ActionButton}"
                        Command="{Binding SaveCommand}" Margin="0,0,16,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Terms of Use -->
            <Border Style="{StaticResource Card}" Opacity="0.7" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Terms of Use" FontSize="13" />
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                               TextWrapping="Wrap" LineHeight="18">
                        Kitsune7Den is provided as-is for personal, non-commercial use only.
                        No warranty or guarantee of any kind is offered. The author is not
                        responsible for data loss, server issues, or any other damages arising
                        from use of this software. Use at your own risk. This tool is not
                        affiliated with or endorsed by The Fun Pimps or Valve.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
